---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
] as const;
---

<header>
  <nav aria-label="Main navigation">
    <a href="/" aria-label="The Healing Home — home page">
      The Healing Home
    </a>
    <ul role="list">
      {
        navLinks.map(({ label, href }) => (
          <li>
            <a href={href}>{label}</a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
