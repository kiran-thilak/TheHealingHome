---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
---

<BaseLayout title="Contact" description="Get in touch with The Healing Home.">
  <section aria-labelledby="contact-heading">
    <h1 id="contact-heading">Contact Us</h1>
    <p>Reach out — we'd love to hear from you.</p>

    <!-- Phase 2: replace action with Formspree or server endpoint -->
    <form method="post" action="#" novalidate>
      <label for="contact-name">Name</label>
      <input id="contact-name" type="text" name="name" required autocomplete="name" />

      <label for="contact-email">Email</label>
      <input id="contact-email" type="email" name="email" required autocomplete="email" />

      <label for="contact-message">Message</label>
      <textarea id="contact-message" name="message" rows="5" required></textarea>

      <Button type="submit">Send Message</Button>
    </form>
  </section>

  <section aria-labelledby="contact-info-heading">
    <h2 id="contact-info-heading">Other Ways to Reach Us</h2>
    <p>[Address, phone, social links — Phase 2]</p>
  </section>
</BaseLayout>
